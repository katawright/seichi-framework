{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "defs.schema.json",
  "$defs": {
    "kebab-case-id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
    },
    "file-path": {
      "type": "string",
      "pattern": "^[a-z].*\\.md$"
    },
    "execution-pattern": {
      "type": "string",
      "enum": ["foundational", "iterative", "continuous"]
    },
    "gate-type": {
      "type": "string",
      "enum": [
        "human-approval",
        "specialized-review",
        "alignment-review",
        "ci-validation-human-approval",
        "ci-validation-human-spot-check",
        "human-execution-required"
      ]
    },
    "role-id": {
      "type": "string",
      "enum": ["pm-ba", "engineer", "architect", "qa", "devops", "appsec", "pjm", "exec"]
    },
    "gate-object": {
      "type": "object",
      "properties": {
        "type": { "$ref": "#/$defs/gate-type" },
        "name": { "type": "string", "minLength": 1 },
        "hard_gate": { "type": "boolean" },
        "responsible_roles": {
          "type": "array",
          "items": { "$ref": "#/$defs/role-id" },
          "minItems": 1
        }
      },
      "required": ["type", "name", "hard_gate"],
      "additionalProperties": false
    },
    "output-object": {
      "type": "object",
      "properties": {
        "artifact": { "type": "string", "minLength": 1 },
        "template": { "$ref": "#/$defs/file-path" },
        "embedded_in": { "type": "string", "minLength": 1 }
      },
      "required": ["artifact"],
      "additionalProperties": false
    },
    "autonomy-level": {
      "type": "string",
      "enum": ["human-led", "collaborative", "ai-led"]
    },
    "oversight-intensity": {
      "type": "string",
      "enum": ["active", "passive", "minimal"]
    },
    "working-location-type": {
      "type": "string",
      "enum": ["artifacts", "source-code"]
    },
    "raci-roles": {
      "type": "object",
      "properties": {
        "R": { "type": "array", "items": { "$ref": "#/$defs/role-id" }, "minItems": 1 },
        "A": { "type": "array", "items": { "$ref": "#/$defs/role-id" }, "minItems": 1 },
        "C": { "type": "array", "items": { "$ref": "#/$defs/role-id" }, "minItems": 1 },
        "I": { "type": "array", "items": { "$ref": "#/$defs/role-id" }, "minItems": 1 }
      },
      "additionalProperties": false
    }
  }
}
