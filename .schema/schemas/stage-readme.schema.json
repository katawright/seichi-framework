{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "stage-readme.schema.json",
  "type": "object",
  "properties": {
    "id": { "$ref": "defs.schema.json#/$defs/id" },
    "inputs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "outputs": {
      "type": "array",
      "items": { "$ref": "defs.schema.json#/$defs/output" },
      "minItems": 1
    },
    "checkpoints": {
      "type": "array",
      "items": { "$ref": "defs.schema.json#/$defs/checkpoint" },
      "minItems": 1
    },
    "checklist": { "$ref": "defs.schema.json#/$defs/file-path" },
    "reference": {
      "oneOf": [
        { "$ref": "defs.schema.json#/$defs/file-path" },
        { "type": "null" }
      ]
    },
    "working_location": {
      "$ref": "defs.schema.json#/$defs/working-location-type"
    },
    "session_log_template": { "$ref": "defs.schema.json#/$defs/file-path" },
    "raci_roles": { "$ref": "defs.schema.json#/$defs/raci-roles" }
  },
  "required": [
    "id",
    "inputs",
    "outputs",
    "checkpoints",
    "checklist",
    "reference",
    "working_location",
    "session_log_template",
    "raci_roles"
  ],
  "additionalProperties": false
}
