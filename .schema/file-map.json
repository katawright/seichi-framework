{
  "mappings": [
    { "glob": "stages/*/README.md", "schema": "stage-readme.schema.json" },
    { "glob": "guides/stages.md", "schema": "stages-guide.schema.json" }
  ],
  "exclude": [
    ".claude/**",
    ".ignore/**",
    ".obsidian/**",
    ".evaluation/**",
    ".schema/**",
    "node_modules/**",
    "templates/**",
    "stages/*/checklist.md",
    "stages/*/reference.md",
    "stages/*/setup.md",
    "stages/*/operations.md",
    "stages/*/pipeline-checklist.md",
    "stages/*/readiness-checklist.md",
    "CLAUDE.md",
    "STYLE_GUIDE.md",
    "QUICKSTART.md",
    "CONTRIBUTING.md",
    "AGENTS.md"
  ]
}
