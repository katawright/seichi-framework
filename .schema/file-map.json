{
  "mappings": [
    { "glob": "stages/*/README.md", "schema": "stage-readme.schema.json" },
    { "glob": "guides/stages.md", "schema": "stages-guide.schema.json" }
  ],
  "exclude": [
    ".claude/**",
    ".ignore/**",
    ".obsidian/**",
    ".evaluation/**",
    ".schema/**",
    "node_modules/**",
    "templates/**",
    "stages/*/checklist.md",
    "stages/*/reference.md",
    "stages/*/setup.md",
    "stages/*/pipeline-checklist.md",
    "CLAUDE.md",
    "STYLE_GUIDE.md",
    "QUICKSTART.md",
    "CONTRIBUTING.md",
    "AGENTS.md"
  ],
  "structureExclude": [
    ".claude/**",
    ".ignore/**",
    ".obsidian/**",
    ".evaluation/**",
    ".schema/**",
    "node_modules/**",
    "templates/**",
    "docs/**",
    "spec/generated/**",
    "stages/*/checklist.md",
    "stages/*/pipeline-checklist.md",
    "CHANGELOG.md",
    "CLAUDE.md",
    "AGENTS.md",
    "CONTRIBUTING.md",
    "QUICKSTART.md"
  ],
  "checkExclude": [
    ".claude/**",
    ".ignore/**",
    ".obsidian/**",
    ".evaluation/**",
    ".schema/**",
    "node_modules/**",
    "docs/**",
    "spec/generated/**"
  ],
  "linkAllowlist": [
    "adr/ADR-*.md",
    "onboarding-tracker/*.md"
  ]
}
