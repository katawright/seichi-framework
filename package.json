{
  "name": "ai-assisted-sdlc-schema",
  "version": "0.0.0",
  "private": true,
  "description": "Front matter schema validation for the AI-Assisted SDLC framework",
  "type": "module",
  "scripts": {
    "validate": "node .schema/validate.mjs",
    "install-hooks": "node -e \"require('fs').cpSync('.schema/hooks/pre-commit','.git/hooks/pre-commit')\"",
    "release": "tsx scripts/release/index.ts",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^25.6.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "archiver": "^7.0.1",
    "fast-glob": "^3.3.0",
    "gray-matter": "^4.0.3",
    "minimatch": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.5",
    "zod": "^4.4.1"
  },
  "dependencies": {
    "hooks": "^0.3.2"
  }
}
